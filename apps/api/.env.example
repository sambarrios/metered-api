# Postgres (matches docker-compose service)
DATABASE_URL=postgres://metered:metered@localhost:5432/metered

# Webhook HMAC shared secret (payment processor). NEVER commit the real value.
WEBHOOK_SIGNING_SECRET=dev-webhook-secret-change-me

# Staff (ops console) auth secret
STAFF_JWT_SECRET=dev-staff-secret-change-me

# API
PORT=3000
NODE_ENV=development
